{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Logs",
  "uid": "logs-overview",
  "tags": ["logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "service", "refId": "LokiVariableQueryEditor-VariableQuery", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Log volume by service",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error / warn rate by service",
      "description": "Lines matching (?i)error|warn|panic|fatal, per service.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)(error|warn|panic|fatal)\" [$__auto]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\"$service\"} |~ \"(?i)$search\""
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "version": 1
}
