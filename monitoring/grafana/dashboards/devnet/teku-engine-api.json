{
 "uid": "devnet-teku-engine-api",
 "title": "Devnet - Teku Engine API (CL to EL)",
 "description": "The engine API is how teku (CL) drives besu (EL): forkchoice_updated sets the head, new_payload validates an incoming block, get_payload asks besu to build a block when teku proposes. It is the CL-EL command channel - errors or latency here stall block validation and, downstream, finality. The upstream Teku dashboard omits this surface.",
 "tags": ["devnet", "engine-api"],
 "timezone": "browser",
 "schemaVersion": 39,
 "refresh": "10s",
 "time": { "from": "now-1h", "to": "now" },
 "panels": [
  { "type": "row", "title": "Health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
  {
   "type": "stat", "title": "engine API errors / min (forkchoice + newPayload)",
   "description": "Errors on the two methods that run every slot. Anything sustained above zero means teku and besu are failing to talk, which stalls block validation.",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(beacon_engine_requests_total{job=\"teku\",outcome=\"error\",method=~\"forkchoice_updated.*|new_payload.*\"}[5m])) * 60" } ],
   "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] } }, "overrides": [] }
  },
  {
   "type": "stat", "title": "get_payload slow share (>500ms)",
   "description": "Fraction of block-build requests to besu that take over 500ms. When teku proposes it has a slot deadline; a rising share here risks missed proposals.",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(beacon_engine_requests_total{job=\"teku\",method=\"get_payloadV4\",interval=~\"\\\\[500,.*|\\\\[1000,.*|\\\\[2000,.*\"}[10m])) / clamp_min(sum(rate(beacon_engine_requests_total{job=\"teku\",method=\"get_payloadV4\"}[10m])), 0.0001)" } ],
   "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.2 }, { "color": "red", "value": 0.5 } ] } }, "overrides": [] }
  },
  {
   "type": "stat", "title": "engine API calls / min (total)",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(beacon_engine_requests_total{job=\"teku\"}[5m])) * 60" } ]
  },
  { "type": "row", "title": "Traffic by method", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "panels": [] },
  {
   "type": "timeseries", "title": "engine API calls / min by method",
   "description": "forkchoice_updated (set head every slot), new_payload (validate incoming block), get_payload (build a block when proposing), get_payload_with_attributes (build when it is teku's turn next).",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (method) (rate(beacon_engine_requests_total{job=\"teku\"}[5m])) * 60", "legendFormat": "{{method}}" } ]
  },
  {
   "type": "timeseries", "title": "success vs error / min",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (outcome) (rate(beacon_engine_requests_total{job=\"teku\"}[5m])) * 60", "legendFormat": "{{outcome}}" } ]
  },
  { "type": "row", "title": "Latency distribution (teku buckets calls itself)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "panels": [] },
  {
   "type": "timeseries", "title": "get_payload latency distribution (build a block)",
   "description": "teku pre-buckets each engine call by latency. This is the block-build call - the one on the proposal deadline. Watch weight shift into the higher buckets.",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (interval) (rate(beacon_engine_requests_total{job=\"teku\",method=\"get_payloadV4\"}[5m])) * 60", "legendFormat": "{{interval}} ms" } ]
  },
  {
   "type": "timeseries", "title": "new_payload latency distribution (validate a block)",
   "description": "The validate-incoming-block call, which runs every slot. Slow buckets here mean besu is slow to execute blocks - a precursor to falling behind.",
   "datasource": { "type": "prometheus", "uid": "prometheus" },
   "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
   "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (interval) (rate(beacon_engine_requests_total{job=\"teku\",method=\"new_payloadV4\"}[5m])) * 60", "legendFormat": "{{interval}} ms" } ]
  }
 ]
}
