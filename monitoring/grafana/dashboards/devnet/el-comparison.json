{
 "uid": "devnet-el-comparison",
 "title": "Devnet - Execution Layer Comparison (besu vs geth)",
 "tags": [
  "devnet",
  "execution"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "refresh": "10s",
 "time": {
  "from": "now-1h",
  "to": "now"
 },
 "panels": [
  {
   "type": "row",
   "title": "Consensus between the two clients",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 0
   },
   "panels": []
  },
  {
   "type": "stat",
   "title": "head divergence (blocks)",
   "description": "besu head minus geth head. Anything but 0 for more than a slot means one client is behind or, worse, on a different chain.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 0,
    "y": 1
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "max(ethereum_blockchain_height{job=\"besu\"}) - max(chain_head_block{job=\"geth\"})"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 1
       },
       {
        "color": "red",
        "value": 3
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "type": "timeseries",
   "title": "chain head per client",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 10,
    "x": 5,
    "y": 1
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "max(ethereum_blockchain_height{job=\"besu\"})",
     "legendFormat": "besu (validating)"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "max(chain_head_block{job=\"geth\"})",
     "legendFormat": "geth (archive)"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "blocks imported / min",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 9,
    "x": 15,
    "y": 1
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "rate(ethereum_blockchain_height{job=\"besu\"}[5m]) * 60",
     "legendFormat": "besu"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "rate(chain_head_block{job=\"geth\"}[5m]) * 60",
     "legendFormat": "geth"
    }
   ]
  },
  {
   "type": "row",
   "title": "Peering and transaction gossip",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 6
   },
   "panels": []
  },
  {
   "type": "stat",
   "title": "geth peers",
   "description": "The two ELs peer with each other over devp2p. Zero means transaction gossip is broken even though blocks keep arriving over the engine API.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 5,
    "x": 0,
    "y": 7
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "p2p_peers{job=\"geth\"}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "type": "timeseries",
   "title": "transaction pool size per client",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 10,
    "x": 5,
    "y": 7
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "besu_transaction_pool_number_of_transactions",
     "legendFormat": "besu"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "txpool_pending{job=\"geth\"}",
     "legendFormat": "geth pending"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "devp2p traffic (bytes/s, geth)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 5,
    "w": 9,
    "x": 15,
    "y": 7
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "rate(p2p_ingress{job=\"geth\"}[5m])",
     "legendFormat": "ingress"
    },
    {
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "rate(p2p_egress{job=\"geth\"}[5m])",
     "legendFormat": "egress"
    }
   ]
  },
  {
   "type": "row",
   "title": "Resource cost of the two storage modes",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 12
   },
   "panels": []
  },
  {
   "type": "timeseries",
   "title": "process CPU (cores)",
   "description": "Measured from cadvisor so both clients are counted the same way - geth does not export process_cpu_seconds_total. geth runs archive, so its cost profile should sit above besu over time.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 0,
    "y": 13
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"besu|geth\"}[5m]))",
     "legendFormat": "{{name}}"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "container memory",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 8,
    "y": 13
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "container_memory_working_set_bytes{name=~\"besu|geth\"}",
     "legendFormat": "{{name}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "bytes"
    },
    "overrides": []
   }
  },
  {
   "type": "timeseries",
   "title": "container disk written / s",
   "description": "The archive node writes every intermediate state node; this is the panel that shows what archive costs on disk.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 6,
    "w": 8,
    "x": 16,
    "y": 13
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (name) (rate(container_fs_writes_bytes_total{name=~\"besu|geth\"}[5m]))",
     "legendFormat": "{{name}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "Bps"
    },
    "overrides": []
   }
  }
 ]
}