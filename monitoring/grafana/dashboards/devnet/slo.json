      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (code) (rate(haproxy_backend_http_responses_total{proxy=~\"archive_.+\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    }
