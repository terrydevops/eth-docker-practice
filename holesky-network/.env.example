# holesky validator stack: besu + teku + teku-validator (+ web3signer) + monitoring
# run from this directory: docker compose up -d
COMPOSE_FILE=../besu/docker-compose.yml:../teku/docker-compose.yml:../teku-validator/docker-compose.yml:../web3signer/docker-compose.yml:../monitoring/docker-compose.yml

NETWORK=holesky
COMPOSE_PROJECT_NAME=eth-holesky
UID=1000
GID=1000

NET_CIDR=10.222.1.0/24
NET_GATEWAY=10.222.1.1
NET_NAME=eth-holesky-network

# execution / consensus
HOST_ALLOWLIST=${NET_GATEWAY}
ENGINE_HOST_ALLOWLIST=${NET_GATEWAY}
EE_ENDPOINT=http://${NET_GATEWAY}:8551
CHECKPOINT=https://checkpoint-sync.holesky.ethpandaops.io
INIT_STATE=https://checkpoint-sync.holesky.ethpandaops.io/eth/v2/debug/beacon/states/finalized

# set your own before starting
VALIDATORS_FEE_RECIPIENT=0x0000000000000000000000000000000000000000
PUBLIC_IP=

# web3signer / postgres (change credentials)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=web3signer
POSTGRES_DSN=jdbc:postgresql://postgres/web3signer

# monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# teku-validator -> web3signer wiring
BEACON_NODE_API_ENDPOINT=http://${NET_GATEWAY}:5051
WEB3SIGNER_ENDPOINT=http://${NET_GATEWAY}:29000
WEB3SIGNER_PUBLIC_KEYS=http://${NET_GATEWAY}:29000/api/v1/eth2/publicKeys
